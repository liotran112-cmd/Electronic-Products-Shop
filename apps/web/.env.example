# ── apps/web environment ─────────────────────────────────────────
# Copy to `.env.local` and fill in. NEXT_PUBLIC_* are exposed to the browser;
# everything else is SERVER-ONLY (never prefix a secret with NEXT_PUBLIC_).

# Supabase --------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=          # server-only — bypasses RLS

# Shopify ---------------------------------------------------------
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_API_VERSION=2025-01
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_ADMIN_API_VERSION=2025-01
SHOPIFY_ADMIN_ACCESS_TOKEN=         # server-only
SHOPIFY_WEBHOOK_SECRET=             # HMAC verification

# Sanity ----------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
SANITY_WEBHOOK_SECRET=

# Algolia ---------------------------------------------------------
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=     # public search key (or minted secured key)
ALGOLIA_ADMIN_KEY=                  # server-only — indexing

# Inngest ---------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Cloudinary ------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=                 # server-only — signed uploads
CLOUDINARY_API_SECRET=              # server-only — signed uploads

# Upstash Redis ---------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend ----------------------------------------------------------
RESEND_API_KEY=

# PostHog ---------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Turnstile -------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
