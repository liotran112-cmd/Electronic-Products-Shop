    "gen:types": "supabase gen types typescript --local > src/types.gen.ts"
  },
  "dependencies": {
    "@repo/env": "workspace:*",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/node": "^22.10.2",
    "eslint": "^9.15.0",
    "typescript": "^5.6.3"
  }
}
